PORT=3009
NODE_ENV=development
# Orígenes extra (opcional): el API ya permite https://matupicks.app y https://www.matupicks.app por defecto.
# También se permiten automáticamente http://localhost:* y http://127.0.0.1:* (Vite admin vs API prod).
CORS_ORIGIN=http://localhost:5174,https://matupicks.app,https://www.matupicks.app

MATUDB_URL=https://db.matudb.com
MATUDB_PROJECT_ID=
MATUDB_API_KEY=
MATUDB_USE_SUPABASE=false

WHATSAPP_ENABLED=false
WHATSAPP_PHONE_FREE=
WHATSAPP_PHONE_VIP=
CHROME_EXECUTABLE_PATH=

LOG_LEVEL=info
ENABLE_CRON=true
# Zona horaria del proceso Node (cron de blog previa usa hora del servidor). En VPS: export TZ=America/Bogota en systemd/pm2.
# TZ=America/Bogota

# Coma separada. Omitir = fábrica usa fútbol + baloncesto (NBA) + tenis + hockey (NHL).
# Solo fútbol: FACTORY_SPORTS=football
FACTORY_SPORTS=football,basketball,tennis,hockey
FACTORY_TIMEZONE=America/Bogota
# VPS: no duplicar monitor live dentro del ciclo de fábrica (ahorra mucha CPU).
FACTORY_CYCLE_INCLUDES_LIVE=false
# Cron node-cron (hora del servidor). VPS pequeño: valores conservadores.
CRON_FACTORY_EXPRESSION=*/15 * * * *
CRON_LIVE_EXPRESSION=*/5 * * * *
CRON_NEWS_EXPRESSION=*/45 * * * *
# Liquidación automática won/lost según marcadores (caché + SoccersAPI). Desactivar: FACTORY_AUTO_SETTLE_ENABLED=false
CRON_SETTLE_EXPRESSION=*/12 * * * *
FACTORY_AUTO_SETTLE_ENABLED=true
# Prioridad de fixtures (coma, minúsculas). Por defecto ya incluye términos Colombia/LatAm.
# FACTORY_PRIORITY_TERMS=libertadores,betplay,colombia,...
# Fábrica: valores por defecto (el código usa los mismos si omites estas líneas en tu .env).
# Nota: la fábrica ahora prioriza fixtures SIN cubrir del día — sube los topes para que cubra Bundesliga,
# Liga BetPlay (Colombia), Liga Pro (Ecuador), Liga 1 (Perú), Brasileirão, Argentina, MLS, etc.
FACTORY_BATCH_FREE=60
FACTORY_BATCH_VIP=60
# Límite de picks por ciclo cuando corres la fábrica con body { latam_only: true } (panel Lote LATAM).
FACTORY_LATAM_BATCH_FREE=45
FACTORY_LATAM_BATCH_VIP=45
# Cuántos partidos distintos procesa la IA en modo LATAM (por defecto mayor que FACTORY_AI_MATCH_LIMIT).
FACTORY_LATAM_AI_MATCH_LIMIT=40
# Lista opcional de rutas ESPN soccer/col.x separadas por coma (sustituye el default Latam).
FACTORY_LATAM_ESPN_PATHS=soccer/col.1,soccer/arg.1,soccer/ecu.1,soccer/per.1,soccer/bra.1,soccer/mex.1,soccer/uru.1

FACTORY_FIXTURE_ROTATION_POOL=80
FACTORY_FIXTURE_ROTATION_WINDOW_MIN=15
FACTORY_AI_MATCH_LIMIT=20
FACTORY_AI_DELAY_MS=2500
FACTORY_MARKETS_PER_MATCH=1
FACTORY_RULE_MARKETS_PER_MATCH=1
FACTORY_AI_LIVE_MATCH_LIMIT=5
LIVE_ALERT_COOLDOWN_MS=480000

# Blog IA: cuántas previas/recaps generar por ciclo y cada cuánto.
BLOG_PREVIAS_CRON=15 */2 * * *
BLOG_PREVIAS_MAX=12
BLOG_RECAPS_MAX=6

# TheSportsDB (respaldo gratuito de fixtures cuando ESPN no devuelve nada — útil para Latam).
# Key pública "3" sirve para uso libre. Pon THESPORTSDB_DISABLED=true para apagarlo.
THESPORTSDB_KEY=3
# THESPORTSDB_DISABLED=false

# SoccersAPI v2.2 — fixtures por fecha (extra LATAM si ESPN/tsdb fallan). Documentación: https://docs.soccersapi.com/fixtures-by-date-6032933e0
SOCCERSAPI_USER=juanlandazury07
SOCCERSAPI_TOKEN=IYtUhVHARO
# Si el schedule global viene vacío en tu plan, lista league_id separados por coma (los ves en /v2.2/leagues/).
SOCCERSAPI_LEAGUE_IDS=
# Filtrar por país ISO2; vacío = incluir todos los partidos que devuelva la API (útil si no mandan country_code).
SOCCERSAPI_LATAM_CC=co,ar,ec,pe,br,mx,cl,uy,py,bo,ve
SOCCERSAPI_MAX_PAGES=25

# POST /api/factory/run-now requiere JWT admin (Bearer). Cron interno no usa esta ruta.
REDIS_URL=redis://localhost:6379

# Wompi: local = pub_test_ + test_integrity_; prod = pub_prod_ + prod_integrity_
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=pub_test_XXXXXXXX
WOMPI_INTEGRITY_SECRET=test_integrity_XXXXXXXX
WOMPI_VIP_MONTHLY_AMOUNT_CENTS=2000000
WOMPI_VIP_ANNUAL_AMOUNT_CENTS=20000000
# Semanal (más caro por día que el mensual; incentiva plan mensual).
WOMPI_VIP_WEEKLY_AMOUNT_CENTS=700000

# Retorno post-pago: Wompi añade ?id=<transaction_id>. Prioridad:
# 1) WOMPI_REDIRECT_URL — URL completa HTTPS (ej. ngrok o prod): https://tudominio.com/predictions/vip
# 2) APP_PUBLIC_URL — debe ser HTTPS público (no localhost) para que Wompi acepte redirect-url.
APP_PUBLIC_URL=http://localhost:5174
# WOMPI_REDIRECT_URL=https://matupicks.app/predictions/vip
# WOMPI_ALLOW_LOCAL_REDIRECT=true

# WOMPI_WEBHOOK_GRANT_VIP=false

# IA fábrica / blog (DeepSeek-compatible: FACTORY_AI_BASE_URL + FACTORY_AI_API_KEY)
FACTORY_AI_ENABLED=true
FACTORY_AI_API_KEY=
FACTORY_AI_BASE_URL=https://api.deepseek.com
FACTORY_AI_MODEL=deepseek-chat
FACTORY_AI_TIMEOUT_MS=12000
# Previas/crónicas: prompt largo; si el cliente muestra "aborted" o 500 por timeout, sube esto (ms).
BLOG_AI_TIMEOUT_MS=180000

# Disparo manual de blogs sin JWT admin (opcional): POST /api/blog/generate-previas Header x-blog-cron-secret
# BLOG_CRON_SECRET=

# Feed /news en la app (`sports_news`): tras el scraper se generan notas con IA si FACTORY_AI_ENABLED=true.
# Opcional: horas de ventana para no saturar (default 8) y máximo de notas MatuPicks en esa ventana (default 6).

